# คัดลอกไฟล์นี้เป็น .env.local แล้วแก้ค่าตามจริง
# คำสั่ง: cp .env.local.example .env.local

# MongoDB (รัน local เช่น `mongod` หรือ Docker: docker run -d -p 27017:27017 mongo)
MONGODB_URI=mongodb://127.0.0.1:27017/activity-gallery

# บัญชีแอดมิน (เปลี่ยนรหัสผ่านก่อนใช้งานจริงเสมอ)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# ใช้เซ็นคุกกี้ session ของแอดมิน ใส่สตริงสุ่มยาวๆ (เช่นรันคำสั่ง: openssl rand -hex 32)
SESSION_SECRET=replace-this-with-a-long-random-string
